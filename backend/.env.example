# Server
PORT=5001
NODE_ENV=production  # IMPORTANT: use 'production' in any deployed env — dev mode leaks password reset tokens in API responses

# MongoDB (local)
MONGODB_URI=mongodb://localhost:27017/commute

# JWT — MUST be different secrets, generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_me_with_a_long_random_hex_string
JWT_REFRESH_SECRET=replace_me_with_a_different_long_random_hex_string

# Token lifetimes
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# Firebase Admin (for verifying OAuth ID tokens)
# Either use a service account JSON path...
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json
# ...or paste the project ID and let Application Default Credentials handle it
FIREBASE_PROJECT_ID=

# Supabase Storage (REQUIRED — server will NOT start without these)
# Get these from: Supabase Dashboard → Project Settings → API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGc...  # service_role key (NOT anon key) — keep secret, never commit
SUPABASE_STORAGE_BUCKET=posts
SUPABASE_CDN_URL=https://your-project-ref.supabase.co/storage/v1/object/public/posts
SUPABASE_ANON_KEY=eyJhbGc...    # anon/publishable key (safe to expose to clients)
